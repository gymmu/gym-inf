# Database
DB_NAME=gyminfdb
DB_USER=gyminfuser
DB_PASSWORD=devpassword123

# Session
SESSION_SECRET=dev-secret-change-in-production-with-64-chars-random-string
SESSION_NAME=gym-inf.sid
SESSION_MAX_AGE=604800000

# Client URL (Vite Dev Server)
CLIENT_URL=http://localhost:5173

# Email - Mailgun HTTP API (recommended)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=noreply@localhost

# Email - Gmail fallback (optional for local dev)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Tokens
JWT_SECRET=dev-jwt-secret-change-in-production
TOKEN_EXPIRY=3600000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10
