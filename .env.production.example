# =============================================================================
# PRODUCTION ENVIRONMENT - Copy to .env and fill in all values
# =============================================================================
# IMPORTANT: Generate secure secrets with: openssl rand -base64 48
# =============================================================================

# Domain (your registered domain pointing to this server)
DOMAIN=api.example.com

# Database
DB_NAME=gyminfdb
DB_USER=gyminfuser
DB_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_24

# Session
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_48
SESSION_NAME=gym-inf.sid
SESSION_MAX_AGE=604800000

# Client URL (where your React app is hosted)
CLIENT_URL=https://gymmu.github.io/gym-inf

# Email - Mailgun SMTP (recommended)
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_USER=postmaster@mg.example.com
MAILGUN_SMTP_PASS=CHANGE_ME
MAILGUN_FROM=noreply@example.com

# Email - Gmail fallback (if Mailgun not configured)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Tokens
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_48
TOKEN_EXPIRY=3600000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5

# Certbot
CERTBOT_EMAIL=your-email@example.com
