# =============================================================================
# PRODUCTION ENVIRONMENT - Copy to .env and fill in all values
# =============================================================================
# IMPORTANT: Generate secure secrets with: openssl rand -base64 48
# =============================================================================

# Domain (your registered domain pointing to this server)
DOMAIN=api.example.com

# Database
DB_NAME=gyminfdb
DB_USER=gyminfuser
# IMPORTANT: Use only alphanumeric characters (no +, /, = or other special chars)
# Generate with: openssl rand -hex 24
DB_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_24

# Full database URL (used by Prisma). Must match DB_USER, DB_PASSWORD, DB_NAME above.
# If your password contains special characters, URL-encode them here.
DATABASE_URL=postgresql://gyminfuser:CHANGE_ME_SAME_AS_DB_PASSWORD@postgres:5432/gyminfdb

# Session
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_48
SESSION_NAME=gym-inf.sid
SESSION_MAX_AGE=604800000

# Client URL (same domain since client runs in Docker on this server)
CLIENT_URL=https://gym-inf.me

# Email - Resend API (recommended)
# Get your API key from: https://resend.com/api-keys
# 3,000 emails/month free - no domain verification needed for testing
RESEND_API_KEY=CHANGE_ME
RESEND_FROM=noreply@example.com

# Email - Gmail fallback (if Mailgun not configured)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Tokens
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_-base64_48
TOKEN_EXPIRY=3600000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5

# Certbot
CERTBOT_EMAIL=your-email@example.com
