generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String @map("password_hash")
  role     Role   @default(USER)

  // Class assignment
  classId Int? @map("class_id")

  // Email verification
  isVerified              Boolean   @default(false) @map("is_verified")
  verificationToken       String?   @unique @map("verification_token")
  verificationTokenExpires DateTime? @map("verification_token_expires")

  // Password reset
  resetPasswordToken   String?   @unique @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  profile         UserProfile?
  chapterProgress ChapterProgress[]
  class           Class?            @relation(fields: [classId], references: [id], onDelete: SetNull)
  chapterFilters  ChapterFilter[]

  @@index([email])
  @@index([verificationToken])
  @@index([resetPasswordToken])
  @@index([classId])
  @@map("users")
}

model UserProfile {
  userId    Int     @id @map("user_id")
  firstName String? @map("first_name") @db.VarChar(100)
  lastName  String? @map("last_name") @db.VarChar(100)
  avatarUrl String? @map("avatar_url") @db.VarChar(500)
  bio       String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model ChapterProgress {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  chapterSlug        String   @map("chapter_slug") @db.VarChar(200)
  understandingLevel Int      @map("understanding_level") // 1 = rot, 2 = gelb, 3 = grün
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterSlug])
  @@index([userId])
  @@map("chapter_progress")
}

model Class {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50) // z.B. "F1c", "1Wb"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users User[]

  @@map("classes")
}

model ChapterFilter {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(100) // z.B. "Nur JavaScript", "FMS Themen"
  chapters  String[] // Array of chapter slugs
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chapter_filters")
}

// Note: The "session" table is managed by connect-pg-simple (createTableIfMissing: true).
// It is NOT defined here to avoid conflicts with prisma db push.
