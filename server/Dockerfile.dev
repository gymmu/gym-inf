FROM node:20-alpine

WORKDIR /app

# Install OpenSSL (required by Prisma on Alpine)
RUN apk add --no-cache openssl

# Install dependencies
COPY package*.json ./
COPY prisma ./prisma/
RUN npm install

# Generate Prisma Client
RUN npx prisma generate

# Create logs directory
RUN mkdir -p logs

EXPOSE 3000

# Development with nodemon for hot reload
CMD ["npm", "run", "dev"]
